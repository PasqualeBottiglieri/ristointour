generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Listing {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  category        String   // ristorante, pizzeria, agriturismo, caseificio, cantina, pasticceria, altro
  planType        String   @default("basic") // basic, premium, sponsor
  location        String
  address         String?  // indirizzo completo (via, civico, CAP, città)
  description     String   // short description
  cuisine         String?
  phone           String?
  website         String?
  email           String?
  bookingLink     String?
  menuLink        String?
  socialLinks     Json?    // [{ platform, url }]

  image           String
  heroImage       String?
  galleryImages   Json?    // [{ src, alt, layout }]
  mapImage        String?

  badge           String?
  badgeStyle      String?
  rating          Float?
  reviewCount     Int?
  priceRange      String?
  priceLabel      String?
  openTime        String?
  philosophy      String?  // full description / about

  dishes          Json?    // [{ icon, name, description }]
  services        Json?    // [{ icon, label }]
  hours           Json?    // [{ day, time }]
  reviews         Json?    // [{ name, avatar, date, rating, text }]

  showOnHomepage  Boolean  @default(false)
  hasDetailPage   Boolean  @default(false)
  displayPriority Int      @default(100)
  featured        Boolean  @default(false)
  status          String   @default("published") // draft, published

  googlePlaceId       String?   @unique
  latitude            Float?
  longitude           Float?
  googleMapsUrl       String?
  sourceProvider      String?   @default("manual")
  sourceLastSyncedAt  DateTime?
  enrichmentStatus    String?   @default("none")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([planType])
  @@index([status])
  @@index([showOnHomepage])
  @@index([displayPriority])
}

model Artist {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  artistType       String   // cantante, band, dj, musicista, performer
  genre            String
  location         String
  shortDescription String
  biography        String?
  musicStyle       String?

  image            String
  galleryImages    Json?    // [{ src, alt }]
  videoEmbeds      Json?    // [{ url, title }]

  phone            String?
  website          String?
  socialLinks      Json?    // [{ platform, url, label }]
  eventTypes       Json?    // ["Matrimoni", "Feste", ...]

  badge            String?
  badgeStyle       String?

  planType         String   @default("basic")
  showOnHomepage   Boolean  @default(false)
  hasDetailPage    Boolean  @default(false)
  displayPriority  Int      @default(100)
  featured         Boolean  @default(false)
  status           String   @default("published")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([artistType])
  @@index([genre])
  @@index([planType])
  @@index([status])
  @@index([showOnHomepage])
}

model Sponsor {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  logo             String
  coverImage       String?
  shortDescription String
  fullDescription  String?
  website          String?
  email            String?
  phone            String?
  sponsorType      String   @default("partner")
  category         String?
  badge            String?
  ctaLabel         String?
  ctaUrl           String?
  featured         Boolean  @default(false)
  showOnHomepage   Boolean  @default(true)
  hasDetailPage    Boolean  @default(false)
  displayPriority  Int      @default(100)
  status           String   @default("draft")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([sponsorType])
  @@index([showOnHomepage])
  @@index([displayPriority])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin") // admin, editor
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
